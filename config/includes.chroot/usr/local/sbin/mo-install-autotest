#!/usr/bin/env bash
set -Eeuo pipefail

readonly expected_token=MO-INSTALL-VDA-01
readonly key_file=/run/mo-ci-luks.key
readonly release_file=/etc/mo-release

read_release_version() {
  local key value
  [[ -r "$release_file" ]] || return 1
  while IFS='=' read -r key value; do
    [[ "$key" == VERSION ]] || continue
    value=${value#\"}
    value=${value%\"}
    [[ "$value" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[A-Za-z0-9._-]+)?$ ]] || return 1
    printf '%s\n' "$value"
    return 0
  done < "$release_file"
  return 1
}

mo_version="$(read_release_version)"
readonly mo_version
ci_passphrase="mo-os-${mo_version}-ci-only"
readonly ci_passphrase

read_token() {
  local path value
  for path in \
    /sys/class/block/vda/serial \
    /sys/block/vda/serial \
    /sys/block/vda/device/serial; do
    if [[ -r "$path" ]]; then
      value="$(tr -d '\000\r\n ' < "$path")"
      if [[ -n "$value" ]]; then
        printf '%s\n' "$value"
        return 0
      fi
    fi
  done

  if command -v udevadm >/dev/null 2>&1 && [[ -b /dev/vda ]]; then
    value="$(
      udevadm info --query=property --name=/dev/vda 2>/dev/null \
        | sed -n -E 's/^ID_SERIAL(_SHORT)?=//p' \
        | head -n 1
    )"
    value="${value//[[:space:]]/}"
    if [[ -n "$value" ]]; then
      printf '%s\n' "$value"
      return 0
    fi
  fi

  return 1
}

emit() {
  local message=$1
  printf '%s\n' "$message" >/dev/console
  if [[ -c /dev/ttyS0 ]]; then
    printf '%s\n' "$message" >/dev/ttyS0
  fi
}

observed_token="$(read_token 2>/dev/null || true)"

case "${1:-run}" in
  check)
    [[ "$observed_token" == "$expected_token" ]]
    ;;
  run)
    emit "MO_OS_INSTALL_TOKEN disk=/dev/vda value=${observed_token:-missing}"
    [[ "$observed_token" == "$expected_token" ]] || exit 0
    umask 077
    printf '%s' "$ci_passphrase" > "$key_file"
    chmod 0600 "$key_file"
    emit "MO_OS_INSTALL_AUTHORIZED disk=/dev/vda mode=encrypted-uefi version=${mo_version}"
    /bin/bash /usr/local/sbin/mo-install \
      --virtual \
      --firmware uefi \
      --disk /dev/vda \
      --erase \
      --username mo-test \
      --lock-user \
      --non-interactive \
      --key-file "$key_file"
    rm -f "$key_file"
    sync
    systemctl poweroff
    ;;
  *)
    echo "unknown autotest action: $1" >&2
    exit 2
    ;;
esac
