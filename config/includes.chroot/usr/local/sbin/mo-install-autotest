#!/usr/bin/env bash
set -Eeuo pipefail

readonly token_path=/sys/firmware/qemu_fw_cfg/by_name/opt/mo/install/raw
readonly expected_token=virtual-disk-v1

read_token() {
  modprobe qemu_fw_cfg 2>/dev/null || true
  for _ in {1..20}; do
    if [[ -r "$token_path" ]]; then
      tr -d '\000\r\n' < "$token_path"
      return 0
    fi
    sleep 0.5
  done
  return 1
}

case "${1:-run}" in
  check)
    [[ "$(read_token 2>/dev/null || true)" == "$expected_token" ]]
    ;;
  run)
    [[ "$(read_token 2>/dev/null || true)" == "$expected_token" ]] || exit 0
    /usr/local/sbin/mo-install \
      --virtual \
      --disk /dev/vda \
      --erase \
      --non-interactive
    sync
    systemctl poweroff
    ;;
  *)
    echo "unknown autotest action: $1" >&2
    exit 2
    ;;
esac
