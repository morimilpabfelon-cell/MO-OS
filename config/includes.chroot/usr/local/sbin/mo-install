#!/usr/bin/env bash
set -Eeuo pipefail

readonly minimum_bytes=$((8 * 1024 * 1024 * 1024))
readonly target=/mnt/mo-target
readonly top_mount=/mnt/mo-btrfs-top
readonly mapper_name=mo_crypt
readonly mapper=/dev/mapper/$mapper_name
readonly ci_key_path=/run/mo-ci-luks.key

disk=''
firmware=''
username=''
key_file=''
virtual_mode=0
erase_confirmed=0
non_interactive=0
lock_user=0
mounted=0
crypt_opened=0

usage() {
  cat <<'USAGE'
MO OS encrypted UEFI virtual disk installer

Usage:
  mo install --virtual --firmware uefi --disk /dev/vda --erase --username NAME

CI-only form:
  mo install --virtual --firmware uefi --disk /dev/vda --erase \
    --username mo-test --lock-user --non-interactive \
    --key-file /run/mo-ci-luks.key

Alpha 0.4 accepts only /dev/vda inside QEMU/KVM. Physical disks, SATA disks,
NVMe devices and every other target are rejected. Interactive installations
require separate encryption and account passwords. The CI key path is accepted
only for the locked non-interactive test account.
USAGE
}

fail() {
  echo "mo-install: $*" >&2
  exit 1
}

emit() {
  local message=$1
  printf '%s\n' "$message" >/dev/console
  if [[ -c /dev/ttyS0 ]]; then
    printf '%s\n' "$message" >/dev/ttyS0
  fi
}

# Invoked indirectly by the EXIT trap.
# shellcheck disable=SC2317
cleanup() {
  if [[ "$mounted" -eq 1 ]]; then
    for path in run sys proc dev; do
      if mountpoint -q "$target/$path"; then
        umount -R "$target/$path" 2>/dev/null || true
      fi
    done
    for path in .snapshots home boot/efi boot; do
      if mountpoint -q "$target/$path"; then
        umount "$target/$path" 2>/dev/null || true
      fi
    done
    if mountpoint -q "$target"; then
      umount "$target" 2>/dev/null || true
    fi
    if mountpoint -q "$top_mount"; then
      umount "$top_mount" 2>/dev/null || true
    fi
  fi
  if [[ "$crypt_opened" -eq 1 ]] && [[ -b "$mapper" ]]; then
    cryptsetup close "$mapper_name" 2>/dev/null || true
  fi
  if [[ "$key_file" == "$ci_key_path" ]]; then
    rm -f "$ci_key_path" 2>/dev/null || true
  fi
}
trap cleanup EXIT

while (($# > 0)); do
  case "$1" in
    --virtual) virtual_mode=1 ;;
    --firmware)
      shift
      (($# > 0)) || fail '--firmware requires a value'
      firmware="$1"
      ;;
    --disk)
      shift
      (($# > 0)) || fail '--disk requires an explicit device path'
      disk="$1"
      ;;
    --username)
      shift
      (($# > 0)) || fail '--username requires a value'
      username="$1"
      ;;
    --key-file)
      shift
      (($# > 0)) || fail '--key-file requires a path'
      key_file="$1"
      ;;
    --erase) erase_confirmed=1 ;;
    --non-interactive) non_interactive=1 ;;
    --lock-user) lock_user=1 ;;
    -h|--help) usage; exit 0 ;;
    *) fail "unknown option: $1" ;;
  esac
  shift
done

[[ ${EUID:-$(id -u)} -eq 0 ]] || fail 'root privileges are required'
[[ "$virtual_mode" -eq 1 ]] || fail 'the Alpha 0.4 installer requires --virtual'
[[ "$firmware" == uefi ]] || fail 'Alpha 0.4 requires --firmware uefi'
[[ "$erase_confirmed" -eq 1 ]] || fail 'destructive installation requires --erase'
[[ -n "$disk" ]] || fail 'no disk was specified'
[[ "$disk" == /dev/vda ]] || fail 'Alpha 0.4 permits only the QEMU/KVM disk /dev/vda'
[[ -b "$disk" ]] || fail "$disk is not a block device"
[[ "$username" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]] || fail 'username is missing or invalid'
[[ "$username" != root ]] || fail 'root cannot be used as the regular account'

if [[ "$non_interactive" -eq 1 ]]; then
  [[ "$lock_user" -eq 1 ]] || fail 'non-interactive mode requires a locked account'
  [[ "$username" == mo-test ]] || fail 'non-interactive mode permits only the mo-test account'
  [[ "$key_file" == "$ci_key_path" ]] || fail "non-interactive mode requires $ci_key_path"
  [[ -f "$key_file" ]] || fail 'CI encryption key file is missing'
  [[ $(stat -c '%a' "$key_file") == 600 ]] || fail 'CI encryption key file must have mode 0600'
else
  [[ "$lock_user" -eq 0 ]] || fail '--lock-user is reserved for non-interactive tests'
  [[ -z "$key_file" ]] || fail '--key-file is reserved for non-interactive tests'
fi

virtualization="$(systemd-detect-virt 2>/dev/null || true)"
case "$virtualization" in
  qemu|kvm) ;;
  *) fail "unsupported virtualization environment: ${virtualization:-none}" ;;
esac

[[ -d /sys/firmware/efi ]] || fail 'the live system was not booted through UEFI'
[[ "$(lsblk -dnro TYPE "$disk")" == disk ]] || fail "$disk is not a whole disk"
size_bytes="$(blockdev --getsize64 "$disk")"
[[ "$size_bytes" =~ ^[0-9]+$ ]] || fail 'could not determine disk capacity'
((size_bytes >= minimum_bytes)) || fail 'virtual disk must be at least 8 GiB'

if lsblk -nrpo NAME,MOUNTPOINT "$disk" | awk 'NF > 1 { found=1 } END { exit !found }'; then
  fail "$disk or one of its partitions is mounted"
fi

for command_name in \
  blkid blockdev btrfs chroot cryptsetup grub-install lsblk mkfs.btrfs \
  mkfs.ext4 mkfs.vfat mount mountpoint parted partprobe rsync stat \
  systemd-detect-virt systemd-machine-id-setup udevadm umount update-grub \
  update-initramfs wipefs; do
  command -v "$command_name" >/dev/null 2>&1 || fail "missing installer dependency: $command_name"
done

luks_passphrase=''
account_password=''
if [[ "$non_interactive" -ne 1 ]]; then
  echo "Target: $disk"
  echo 'Firmware: UEFI'
  echo 'Root: LUKS2 + Btrfs'
  echo "Virtualization: $virtualization"
  echo "Account: $username"
  echo 'All data on the virtual disk will be destroyed.'
  read -r -p 'Type ERASE-MO-ENCRYPTED to continue: ' confirmation
  [[ "$confirmation" == ERASE-MO-ENCRYPTED ]] || fail 'confirmation did not match'

  read -r -s -p 'LUKS encryption passphrase: ' luks_passphrase
  printf '\n'
  read -r -s -p 'Repeat LUKS passphrase: ' luks_repeat
  printf '\n'
  [[ -n "$luks_passphrase" ]] || fail 'LUKS passphrase cannot be empty'
  [[ "$luks_passphrase" == "$luks_repeat" ]] || fail 'LUKS passphrases did not match'
  unset luks_repeat

  read -r -s -p "Password for $username: " account_password
  printf '\n'
  read -r -s -p 'Repeat account password: ' account_repeat
  printf '\n'
  [[ -n "$account_password" ]] || fail 'account password cannot be empty'
  [[ "$account_password" == "$account_repeat" ]] || fail 'account passwords did not match'
  unset account_repeat
fi

esp_part="${disk}1"
boot_part="${disk}2"
crypt_part="${disk}3"

printf '%s\n' '[1/11] Partitioning disposable encrypted UEFI virtual disk'
wipefs --all --force "$disk"
parted --script "$disk" mklabel gpt
parted --script "$disk" mkpart ESP fat32 1MiB 513MiB
parted --script "$disk" set 1 esp on
parted --script "$disk" mkpart MO_BOOT ext4 513MiB 1537MiB
parted --script "$disk" mkpart MO_CRYPT 1537MiB 100%
partprobe "$disk"
udevadm settle
[[ -b "$esp_part" ]] || fail "partition did not appear: $esp_part"
[[ -b "$boot_part" ]] || fail "partition did not appear: $boot_part"
[[ -b "$crypt_part" ]] || fail "partition did not appear: $crypt_part"

printf '%s\n' '[2/11] Creating EFI and boot filesystems'
mkfs.vfat -F 32 -n MO_EFI "$esp_part"
mkfs.ext4 -F -L MO_BOOT "$boot_part"

printf '%s\n' '[3/11] Creating and opening LUKS2 root container'
if [[ "$non_interactive" -eq 1 ]]; then
  cryptsetup luksFormat --type luks2 --batch-mode --key-file "$key_file" "$crypt_part"
  cryptsetup open --key-file "$key_file" "$crypt_part" "$mapper_name"
else
  printf '%s' "$luks_passphrase" | cryptsetup luksFormat \
    --type luks2 --batch-mode --key-file=- "$crypt_part"
  printf '%s' "$luks_passphrase" | cryptsetup open \
    --key-file=- "$crypt_part" "$mapper_name"
  unset luks_passphrase
fi
crypt_opened=1
[[ -b "$mapper" ]] || fail 'LUKS mapper did not appear'

printf '%s\n' '[4/11] Creating Btrfs subvolumes'
mkfs.btrfs -f -L MO_ROOT "$mapper"
rm -rf "$target" "$top_mount"
mkdir -p "$target" "$top_mount"
mount "$mapper" "$top_mount"
mounted=1
btrfs subvolume create "$top_mount/@"
btrfs subvolume create "$top_mount/@home"
btrfs subvolume create "$top_mount/@snapshots"
umount "$top_mount"

mount -o subvol=@,noatime,compress=zstd:3,space_cache=v2 "$mapper" "$target"
mkdir -p "$target/home" "$target/.snapshots" "$target/boot/efi"
mount -o subvol=@home,noatime,compress=zstd:3,space_cache=v2 "$mapper" "$target/home"
mount -o subvol=@snapshots,noatime,compress=zstd:3,space_cache=v2 "$mapper" "$target/.snapshots"
mount "$boot_part" "$target/boot"
mkdir -p "$target/boot/efi"
mount "$esp_part" "$target/boot/efi"

printf '%s\n' '[5/11] Copying MO OS live root'
rsync -aHAXx --numeric-ids \
  --exclude='/dev/*' \
  --exclude='/proc/*' \
  --exclude='/sys/*' \
  --exclude='/run/*' \
  --exclude='/tmp/*' \
  --exclude='/mnt/*' \
  --exclude='/media/*' \
  --exclude='/lost+found' \
  --exclude='/live/*' \
  --exclude='/var/log/*' \
  / "$target/"

luks_uuid="$(cryptsetup luksUUID "$crypt_part")"
btrfs_uuid="$(blkid -s UUID -o value "$mapper")"
boot_uuid="$(blkid -s UUID -o value "$boot_part")"
esp_uuid="$(blkid -s UUID -o value "$esp_part")"
[[ -n "$luks_uuid" ]] || fail 'LUKS UUID is empty'
[[ -n "$btrfs_uuid" ]] || fail 'Btrfs UUID is empty'
[[ -n "$boot_uuid" ]] || fail 'boot filesystem UUID is empty'
[[ -n "$esp_uuid" ]] || fail 'EFI filesystem UUID is empty'

cat > "$target/etc/crypttab" <<CRYPTTAB
$mapper_name UUID=$luks_uuid none luks,initramfs
CRYPTTAB
cat > "$target/etc/fstab" <<FSTAB
UUID=$btrfs_uuid / btrfs subvol=@,defaults,noatime,compress=zstd:3,space_cache=v2 0 0
UUID=$btrfs_uuid /home btrfs subvol=@home,defaults,noatime,compress=zstd:3,space_cache=v2 0 0
UUID=$btrfs_uuid /.snapshots btrfs subvol=@snapshots,defaults,noatime,compress=zstd:3,space_cache=v2 0 0
UUID=$boot_uuid /boot ext4 defaults,noatime 0 2
UUID=$esp_uuid /boot/efi vfat umask=0077 0 2
FSTAB
printf '%s\n' 'CRYPTSETUP=y' > "$target/etc/initramfs-tools/conf.d/mo-cryptroot"
printf '%s\n' 'mo-os' > "$target/etc/hostname"
cat > "$target/etc/hosts" <<'HOSTS'
127.0.0.1 localhost
127.0.1.1 mo-os
::1 localhost ip6-localhost ip6-loopback
HOSTS
cat > "$target/etc/mo-installed" <<MARKER
MO_INSTALLATION=virtual-uefi-encrypted-alpha
MO_INSTALLER_VERSION=0.4.0-alpha.1
MO_PRIMARY_USER=$username
MO_ROOT_ENCRYPTION=LUKS2
MO_ROOT_FILESYSTEM=Btrfs
MARKER

rm -f "$target/etc/machine-id"
systemd-machine-id-setup --root="$target"

for path in dev proc sys run; do
  mkdir -p "$target/$path"
  mount --rbind "/$path" "$target/$path"
  mount --make-rslave "$target/$path"
done

cat > "$target/etc/default/grub" <<'GRUB'
GRUB_DEFAULT=0
GRUB_TIMEOUT=1
GRUB_DISTRIBUTOR="MO OS"
GRUB_CMDLINE_LINUX_DEFAULT="console=tty0 console=ttyS0,115200n8"
GRUB_CMDLINE_LINUX=""
GRUB_TERMINAL="console serial"
GRUB_SERIAL_COMMAND="serial --speed=115200 --unit=0 --word=8 --parity=no --stop=1"
GRUB

printf '%s\n' '[6/11] Creating persistent user'
chroot "$target" useradd --create-home --shell /bin/bash --groups sudo "$username"
if [[ "$non_interactive" -eq 1 ]]; then
  chroot "$target" passwd --lock "$username" >/dev/null
else
  printf '%s:%s\n' "$username" "$account_password" | chroot "$target" chpasswd
  unset account_password
fi
chroot "$target" passwd --lock root >/dev/null 2>&1 || true

printf '%s\n' '[7/11] Preparing encrypted initramfs and recovery services'
chroot "$target" systemctl enable \
  mo-installed-ready.service \
  mo-recovery-test-mutate.service \
  mo-recovery-verify.service
chroot "$target" update-initramfs -u -k all

printf '%s\n' '[8/11] Installing UEFI bootloader'
chroot "$target" grub-install \
  --target=x86_64-efi \
  --efi-directory=/boot/efi \
  --bootloader-id=MOOS \
  --removable \
  --no-nvram \
  --recheck
chroot "$target" update-grub
[[ -f "$target/boot/efi/EFI/BOOT/BOOTX64.EFI" ]] || fail 'UEFI fallback loader was not created'

printf '%s\n' '[9/11] Creating immutable initial root snapshot'
btrfs subvolume snapshot -r "$target" "$target/.snapshots/initial"
[[ "$(btrfs property get -ts "$target/.snapshots/initial" ro)" == 'ro=true' ]] || \
  fail 'initial snapshot is not read-only'

if [[ "$non_interactive" -eq 1 ]]; then
  touch "$target/boot/mo-recovery-test-once"
fi

printf '%s\n' '[10/11] Flushing filesystem state'
sync

printf '%s\n' '[11/11] Installation complete'
message="MO_OS_INSTALL_COMPLETE disk=${disk} firmware=uefi encryption=luks2 filesystem=btrfs luks_uuid=${luks_uuid} snapshot=initial user=${username}"
emit "$message"
logger -t mo-install "$message" || true
