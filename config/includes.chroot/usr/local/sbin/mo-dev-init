#!/usr/bin/env bash
set -Eeuo pipefail

readonly machine_name=mo-dev
readonly target=/var/lib/machines/mo-dev
readonly release=2026.07.01
readonly archive="archlinux-bootstrap-${release}-x86_64.tar.zst"
readonly archive_url="https://geo.mirror.pkgbuild.com/iso/${release}/${archive}"
readonly archive_sha256="9cadf82e389427fb61739ad3b0c213b2abd331354fab6460972e4e52bb8ff9e8"

if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
  echo 'mo-dev-init must run as root.' >&2
  exit 1
fi

[[ ! -e "$target" ]] || {
  echo "$target already exists; refusing to overwrite it." >&2
  exit 1
}

for command_name in curl sha256sum tar systemd-nspawn systemd-firstboot; do
  command -v "$command_name" >/dev/null 2>&1 || {
    echo "Missing requirement: $command_name" >&2
    exit 1
  }
done

workdir="$(mktemp -d)"
trap 'rm -rf "$workdir"' EXIT

curl --fail --location --proto '=https' --tlsv1.2 \
  --output "$workdir/$archive" "$archive_url"
printf '%s  %s\n' "$archive_sha256" "$workdir/$archive" | sha256sum --check --status

echo 'Verified Arch bootstrap archive.'
mkdir -p "$workdir/extract" "$target"
tar --use-compress-program=unzstd -xpf "$workdir/$archive" -C "$workdir/extract"

source_root="$workdir/extract/root.x86_64"
[[ -d "$source_root" ]] || {
  echo 'Unexpected Arch bootstrap layout.' >&2
  exit 1
}

cp -a "$source_root"/. "$target"/
cp --dereference /etc/resolv.conf "$target/etc/resolv.conf"
systemd-firstboot --root="$target" --hostname="$machine_name" --locale=C.UTF-8 --timezone=UTC

systemd-nspawn -D "$target" /usr/bin/pacman-key --init
systemd-nspawn -D "$target" /usr/bin/pacman-key --populate archlinux
systemd-nspawn -D "$target" /usr/bin/pacman -Syu --noconfirm --needed \
  base base-devel git rust python nodejs npm

mkdir -p /srv/mo-projects
systemctl enable "systemd-nspawn@${machine_name}.service"

echo 'Arch development domain created.'
echo 'Enter with: mo dev'
