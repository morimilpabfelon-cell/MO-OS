#!/usr/bin/env bash
set -Eeuo pipefail

release_file=/etc/mo-release
machine_name=mo-dev
executor_coordinator=/usr/local/sbin/mo-executord

show_help() {
  cat <<'EOF_HELP'
MO OS command interface

Usage: mo <command> [options]

Commands:
  status      Show MO OS, encryption and filesystem status
  doctor      Validate the terminal, recovery, trust and executor foundation
  dev-init    Create the pinned Arch development domain
  dev         Open a shell in the Arch development domain
  dev-status  Show development-domain status
  executor    Initialize, pair, recover and inspect the Morimil-controlled executor
  install     Install only to an authorized disposable virtual disk
  snapshot    Create or list read-only Btrfs root snapshots
  recovery    Roll back an encrypted virtual installation from the live ISO
  update      Verify, apply or inspect signed MO OS updates
  help        Show this help

Morimil-controlled executor:
  mo executor init
  mo executor pair --controller-key FILE --instance-id ID --controller-body-id ID
  mo executor status
  mo executor recover
  mo executor process --bundle DIR
  mo executor start
  mo executor stop

Encrypted UEFI virtual installer:
  mo install --virtual --firmware uefi --disk /dev/vda --erase --username NAME

Recovery from the live ISO:
  mo recovery rollback --virtual --firmware uefi --disk /dev/vda --snapshot NAME

Signed updates:
  mo update verify --bundle DIR
  mo update apply --bundle DIR
  mo update status
EOF_HELP
}

status() {
  [[ -r "$release_file" ]] && cat "$release_file"
  printf 'KERNEL="%s"\n' "$(uname -r)"
  printf 'VIRTUALIZATION="%s"\n' "$(systemd-detect-virt 2>/dev/null || echo none)"
  if [[ -d /sys/firmware/efi ]]; then
    echo 'FIRMWARE="uefi"'
  else
    echo 'FIRMWARE="bios"'
  fi
  if [[ -r /etc/mo-installed ]]; then
    echo 'INSTALLATION="persistent"'
    cat /etc/mo-installed
  else
    echo 'INSTALLATION="live"'
  fi
  if findmnt -n / >/dev/null 2>&1; then
    printf 'ROOT_FILESYSTEM="%s"\n' "$(findmnt -n -o FSTYPE /)"
    printf 'ROOT_SOURCE="%s"\n' "$(findmnt -n -o SOURCE /)"
  fi
}

doctor() {
  local failures=0
  for command_name in \
    bash blkid blockdev btrfs chroot cryptsetup curl findmnt git grub-install \
    lsblk machinectl mkfs.btrfs mkfs.ext4 mkfs.vfat mount openssl parted python3 \
    rsync sha256sum systemctl systemd-nspawn tar timeout update-grub wipefs zstd; do
    if command -v "$command_name" >/dev/null 2>&1; then
      printf '[ok] %s\n' "$command_name"
    else
      printf '[missing] %s\n' "$command_name" >&2
      failures=$((failures + 1))
    fi
  done
  [[ -r "$release_file" ]] || {
    echo '[missing] /etc/mo-release' >&2
    failures=$((failures + 1))
  }
  for helper in mo-install mo-recovery mo-snapshot mo-update mo-dev-init; do
    [[ -x "/usr/local/sbin/$helper" ]] || {
      echo "[missing or not executable] $helper" >&2
      failures=$((failures + 1))
    }
  done
  for python_helper in mo-bodyd mo-executord; do
    [[ -r "/usr/local/sbin/$python_helper" && ! -L "/usr/local/sbin/$python_helper" ]] || {
      echo "[missing, unreadable or linked] $python_helper" >&2
      failures=$((failures + 1))
    }
  done
  for coordinator_module in mo_executord_base.py mo_executord_core.py mo_executord_state.py; do
    [[ -r "/usr/local/libexec/mo-executord/$coordinator_module" && ! -L "/usr/local/libexec/mo-executord/$coordinator_module" ]] || {
      echo "[missing, unreadable or linked] mo-executord/$coordinator_module" >&2
      failures=$((failures + 1))
    }
  done
  for native_helper in mo-arch-dispatch mo-arch-worker; do
    [[ -x "/usr/local/libexec/$native_helper" ]] || {
      echo "[missing or not executable] $native_helper" >&2
      failures=$((failures + 1))
    }
  done
  [[ -r /etc/systemd/system/mo-bodyd.service ]] || {
    echo '[missing] mo-bodyd.service' >&2
    failures=$((failures + 1))
  }
  if ((failures > 0)); then
    echo "MO OS has $failures missing requirement(s)." >&2
    return 1
  fi
  echo 'MO OS encrypted recovery, signed updates and durable Morimil executor foundation is healthy.'
}

dev_init() {
  exec sudo /usr/local/sbin/mo-dev-init
}

dev_shell() {
  [[ -d "/var/lib/machines/$machine_name" ]] || {
    echo 'Arch development domain is not initialized. Run: mo dev-init' >&2
    exit 1
  }
  sudo machinectl start "$machine_name" >/dev/null 2>&1 || true
  exec sudo machinectl shell "root@${machine_name}"
}

dev_status() {
  if [[ -d "/var/lib/machines/$machine_name" ]]; then
    machinectl status "$machine_name" || true
  else
    echo 'Arch development domain: not initialized'
  fi
}

executor() {
  shift
  case "${1:-status}" in
    init)
      exec sudo /usr/bin/python3 "$executor_coordinator" init
      ;;
    pair)
      shift
      sudo /usr/bin/python3 "$executor_coordinator" pair "$@"
      sudo systemctl enable --now mo-bodyd.service
      ;;
    status)
      exec sudo /usr/bin/python3 "$executor_coordinator" status
      ;;
    recover)
      exec sudo /usr/bin/python3 "$executor_coordinator" recover
      ;;
    process)
      shift
      exec sudo /usr/bin/python3 "$executor_coordinator" process "$@"
      ;;
    start)
      exec sudo systemctl start mo-bodyd.service
      ;;
    stop)
      exec sudo systemctl stop mo-bodyd.service
      ;;
    *)
      echo 'Usage: mo executor {init|pair|status|recover|process|start|stop} [options]' >&2
      exit 2
      ;;
  esac
}

install() {
  shift
  exec sudo /usr/local/sbin/mo-install "$@"
}

snapshot() {
  shift
  exec sudo /bin/bash /usr/local/sbin/mo-snapshot "$@"
}

recovery() {
  shift
  exec sudo /bin/bash /usr/local/sbin/mo-recovery "$@"
}

update() {
  shift
  case "${1:-status}" in
    verify|status)
      exec /bin/bash /usr/local/sbin/mo-update "$@"
      ;;
    apply)
      exec sudo /bin/bash /usr/local/sbin/mo-update "$@"
      ;;
    *)
      echo 'Usage: mo update {verify|apply|status} [options]' >&2
      exit 2
      ;;
  esac
}

case "${1:-help}" in
  status) status ;;
  doctor) doctor ;;
  dev-init) dev_init ;;
  dev) dev_shell ;;
  dev-status) dev_status ;;
  executor) executor "$@" ;;
  install) install "$@" ;;
  snapshot) snapshot "$@" ;;
  recovery) recovery "$@" ;;
  update) update "$@" ;;
  help|-h|--help) show_help ;;
  *) echo "Unknown command: $1" >&2; show_help >&2; exit 2 ;;
esac
