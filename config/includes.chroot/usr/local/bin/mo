#!/usr/bin/env bash
set -Eeuo pipefail

release_file=/etc/mo-release
machine_name=mo-dev

show_help() {
  cat <<'EOF_HELP'
MO OS command interface

Usage: mo <command> [options]

Commands:
  status      Show MO OS, encryption and filesystem status
  doctor      Validate the terminal, installer and recovery foundation
  dev-init    Create the pinned Arch development domain
  dev         Open a shell in the Arch development domain
  dev-status  Show development-domain status
  install     Install only to an authorized disposable virtual disk
  snapshot    Create or list read-only Btrfs root snapshots
  recovery    Roll back an encrypted virtual installation from the live ISO
  help        Show this help

Encrypted UEFI virtual installer:
  mo install --virtual --firmware uefi --disk /dev/vda --erase --username NAME

Recovery from the live ISO:
  mo recovery rollback --virtual --firmware uefi --disk /dev/vda --snapshot NAME
EOF_HELP
}

status() {
  [[ -r "$release_file" ]] && cat "$release_file"
  printf 'KERNEL="%s"\n' "$(uname -r)"
  printf 'VIRTUALIZATION="%s"\n' "$(systemd-detect-virt 2>/dev/null || echo none)"
  if [[ -d /sys/firmware/efi ]]; then
    echo 'FIRMWARE="uefi"'
  else
    echo 'FIRMWARE="bios"'
  fi
  if [[ -r /etc/mo-installed ]]; then
    echo 'INSTALLATION="persistent"'
    cat /etc/mo-installed
  else
    echo 'INSTALLATION="live"'
  fi
  if findmnt -n / >/dev/null 2>&1; then
    printf 'ROOT_FILESYSTEM="%s"\n' "$(findmnt -n -o FSTYPE /)"
    printf 'ROOT_SOURCE="%s"\n' "$(findmnt -n -o SOURCE /)"
  fi
}

doctor() {
  local failures=0
  for command_name in \
    bash blkid blockdev btrfs chroot cryptsetup curl findmnt git grub-install \
    lsblk machinectl mkfs.btrfs mkfs.ext4 mkfs.vfat mount parted rsync \
    sha256sum systemd-nspawn tar update-grub wipefs zstd; do
    if command -v "$command_name" >/dev/null 2>&1; then
      printf '[ok] %s\n' "$command_name"
    else
      printf '[missing] %s\n' "$command_name" >&2
      failures=$((failures + 1))
    fi
  done
  [[ -r "$release_file" ]] || { echo '[missing] /etc/mo-release' >&2; failures=$((failures + 1)); }
  for helper in mo-install mo-recovery mo-snapshot; do
    [[ -r "/usr/local/sbin/$helper" ]] || {
      echo "[missing] $helper" >&2
      failures=$((failures + 1))
    }
  done
  if ((failures > 0)); then
    echo "MO OS has $failures missing requirement(s)." >&2
    return 1
  fi
  echo 'MO OS encrypted installer, snapshot and recovery foundation is healthy.'
}

dev_init() {
  exec sudo /usr/local/sbin/mo-dev-init
}

dev_shell() {
  [[ -d "/var/lib/machines/$machine_name" ]] || {
    echo 'Arch development domain is not initialized. Run: mo dev-init' >&2
    exit 1
  }
  sudo machinectl start "$machine_name" >/dev/null 2>&1 || true
  exec sudo machinectl shell "root@${machine_name}"
}

dev_status() {
  if [[ -d "/var/lib/machines/$machine_name" ]]; then
    machinectl status "$machine_name" || true
  else
    echo 'Arch development domain: not initialized'
  fi
}

install() {
  shift
  exec sudo /usr/local/sbin/mo-install "$@"
}

snapshot() {
  shift
  exec sudo /bin/bash /usr/local/sbin/mo-snapshot "$@"
}

recovery() {
  shift
  exec sudo /bin/bash /usr/local/sbin/mo-recovery "$@"
}

case "${1:-help}" in
  status) status ;;
  doctor) doctor ;;
  dev-init) dev_init ;;
  dev) dev_shell ;;
  dev-status) dev_status ;;
  install) install "$@" ;;
  snapshot) snapshot "$@" ;;
  recovery) recovery "$@" ;;
  help|-h|--help) show_help ;;
  *) echo "Unknown command: $1" >&2; show_help >&2; exit 2 ;;
esac
